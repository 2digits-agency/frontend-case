{
  "name": "2digits-blog-case",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "next dev --turbo",
    "dev": "turbo dev:web",
    "build:web": "next build",
    "build": "turbo build:web",
    "start": "next start",
    "types": "tsc --noEmit",
    "fix": "pnpm '/(lint|format):fix$/'",
    "format": "prettier \"**/*\" --ignore-unknown --check --cache",
    "format:fix": "prettier \"**/*\" --ignore-unknown --write --cache",
    "lint": "eslint . --cache --max-warnings 0",
    "lint:fix": "eslint . --fix --cache",
    "check": "turbo --continue format lint types",
    "codegen": "graphql-codegen"
  },
  "dependencies": {
    "graphql": "^16.13.0",
    "graphql-request": "^7.4.0",
    "next": "^16.1.6",
    "ofetch": "^1.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@2digits/eslint-config": "^5.1.12",
    "@2digits/prettier-config": "^4.0.38",
    "@2digits/tsconfig": "^0.8.6",
    "@graphql-codegen/cli": "^6.1.2",
    "@graphql-codegen/import-types-preset": "^3.0.1",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-generic-sdk": "^4.1.0",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "turbo": "^2.9.9",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.4.1",
  "prettier": "@2digits/prettier-config"
}
